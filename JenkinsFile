    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out code from Repository...'
            }
        }
        stage('Build') {
            steps {
                echo 'Building the Student Result Portal...'
            }
        }
        stage('Test') {
            steps {
                echo 'Running Tests...'
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying Application...'
            }
        }
    }
}
